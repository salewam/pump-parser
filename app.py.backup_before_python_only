"""
CDM Pump Parser - Web Interface
Веб-интерфейс для парсинга PDF каталогов насосов и загрузки в ONIS Bot
"""

import traceback
import logging
from datetime import datetime

# Настройка логирования
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s | %(levelname)s | %(message)s',
    handlers=[
        logging.FileHandler('/root/pump_parser/app_errors.log', encoding='utf-8'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

# Глобальный список ошибок (последние 50)
ERROR_LOG = []
MAX_ERRORS = 50

def log_error(error_type, message, traceback_str=None):
    """Логирует ошибку в файл и в память"""
    error_entry = {
        'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
        'type': error_type,
        'message': str(message),
        'traceback': traceback_str
    }
    ERROR_LOG.insert(0, error_entry)
    if len(ERROR_LOG) > MAX_ERRORS:
        ERROR_LOG.pop()
    logger.error(f"{error_type}: {message}")
    if traceback_str:
        logger.error(traceback_str)

from flask import Flask, render_template, request, jsonify, send_from_directory
from flask_cors import CORS
import os
import json
import shutil
from datetime import datetime
from werkzeug.utils import secure_filename
import cdm_parser_v2 as cdm_parser

app = Flask(__name__)
CORS(app)  # Включаем CORS для всех роутов

# Конфигурация
UPLOAD_FOLDER = 'uploads'
ALLOWED_EXTENSIONS = {'pdf'}
MAX_FILE_SIZE = 100 * 1024 * 1024  # 50MB
ONIS_BASE_PATH = '/root/ONIS_BASE.json'

app.config['UPLOAD_FOLDER'] = UPLOAD_FOLDER
app.config['MAX_CONTENT_LENGTH'] = MAX_FILE_SIZE

# Глобальная переменная для хранения последних распарсенных данных
last_parsed_data = None


def allowed_file(filename):
    """Проверка допустимого расширения файла"""
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS


def load_onis_base():
    """Загрузка базы данных ONIS"""
    try:
        if not os.path.exists(ONIS_BASE_PATH):
            return []
        with open(ONIS_BASE_PATH, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception as e:
        print(f"Ошибка загрузки базы: {e}")
        return []


def save_onis_base(data):
    """
    Сохранение базы данных ONIS с созданием бэкапа
    Использует atomic write для безопасности
    """
    try:
        # Создаем бэкап
        if os.path.exists(ONIS_BASE_PATH):
            backup_path = f"{ONIS_BASE_PATH}.backup.{datetime.now().strftime('%Y%m%d_%H%M%S')}"
            shutil.copy2(ONIS_BASE_PATH, backup_path)

        # Atomic write через временный файл
        temp_path = f"{ONIS_BASE_PATH}.tmp"
        with open(temp_path, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

        # Переименовываем временный файл в основной
        os.replace(temp_path, ONIS_BASE_PATH)

        return True
    except Exception as e:
        print(f"Ошибка сохранения базы: {e}")
        return False


def merge_pumps(existing_pumps, new_pumps):
    """
    Объединяет новые данные CDM с существующей базой

    Args:
        existing_pumps: list - текущая база из ONIS_BASE.json
        new_pumps: list - новые данные из парсера

    Returns:
        dict: {"merged": list, "stats": {"added": int, "duplicates": int, "total": int}}
    """
    # Создаем set для быстрой проверки дубликатов
    existing_keys = {
        (p['id'], p['kw'], p['q'], p['head_m'])
        for p in existing_pumps
    }

    added = 0
    duplicates = 0

    for pump in new_pumps:
        key = (pump['id'], pump['kw'], pump['q'], pump['head_m'])
        if key not in existing_keys:
            existing_pumps.append(pump)
            existing_keys.add(key)
            added += 1
        else:
            duplicates += 1

    # Сортируем по id
    existing_pumps.sort(key=lambda x: x['id'])

    return {
        "merged": existing_pumps,
        "stats": {
            "added": added,
            "duplicates": duplicates,
            "total": len(existing_pumps)
        }
    }


def get_database_stats():
    """Получение статистики по базе данных"""
    base = load_onis_base()

    if not base:
        return {
            "total": 0,
            "models": 0,
            "cdm_count": 0,
            "mv_count": 0,
            "file_size": 0,
            "last_modified": None
        }

    # Подсчет уникальных моделей
    models = set(p['id'] for p in base)
    cdm_count = len([p for p in base if 'CDM' in p.get('id', '').upper()])
    mv_count = len([p for p in base if 'MV' in p.get('id', '').upper()])

    # Размер файла
    file_size = 0
    last_modified = None
    if os.path.exists(ONIS_BASE_PATH):
        file_size = os.path.getsize(ONIS_BASE_PATH)
        last_modified = datetime.fromtimestamp(os.path.getmtime(ONIS_BASE_PATH)).strftime('%Y-%m-%d %H:%M:%S')

    return {
        "total": len(base),
        "models": len(models),
        "cdm_count": cdm_count,
        "mv_count": mv_count,
        "file_size": file_size,
        "file_size_mb": round(file_size / 1024 / 1024, 2),
        "last_modified": last_modified
    }


@app.route('/')
def index():
    """Главная страница"""
    stats = get_database_stats()
    return render_template('index.html', stats=stats)


@app.route('/upload', methods=['POST'])
def upload_file():
    """Загрузка и парсинг PDF файла"""
    global last_parsed_data

    if 'file' not in request.files:
        return jsonify({"error": "Файл не найден"}), 400

    file = request.files['file']

    if file.filename == '':
        return jsonify({"error": "Файл не выбран"}), 400

    if not allowed_file(file.filename):
        return jsonify({"error": "Допустимы только PDF файлы"}), 400

    try:
        # Сохраняем файл
        filename = secure_filename(file.filename)
        filepath = os.path.join(app.config['UPLOAD_FOLDER'], filename)
        file.save(filepath)

        # Парсим PDF
        try:
            logger.info(f"Начало парсинга: {filepath}")
            pumps = cdm_parser.extract_cdm_from_pdf(filepath)
            logger.info(f"Парсинг завершён: {len(pumps)} записей")
        except MemoryError as e:
            log_error('MemoryError', 'Недостаточно памяти для парсинга', traceback.format_exc())
            return jsonify({'error': 'Недостаточно памяти. Попробуйте файл меньшего размера'}), 500
        except Exception as e:
            log_error('ParsingError', f'Ошибка парсинга: {str(e)}', traceback.format_exc())
            return jsonify({'error': f'Ошибка парсинга: {str(e)}'}), 500

        if not pumps:
            os.remove(filepath)
            return jsonify({"error": "Данные не найдены в PDF"}), 400

        # Сохраняем данные для последующего мержа
        last_parsed_data = pumps

        # Статистика по сериям
        series_stats = {}
        for p in pumps:
            series = p['id'].split('-')[0] if '-' in p['id'] else p['id']
            if series not in series_stats:
                series_stats[series] = 0
            series_stats[series] += 1

        # Удаляем временный файл
        os.remove(filepath)

        return jsonify({
            "success": True,
            "data": pumps,
            "stats": {
                "total": len(pumps),
                "series": series_stats,
                "models": len(set(p['id'] for p in pumps))
            }
        })

    except Exception as e:
        return jsonify({"error": f"Ошибка парсинга: {str(e)}"}), 500


@app.route('/merge', methods=['POST'])
def merge_to_database():
    """Объединение распарсенных данных с базой ONIS"""
    global last_parsed_data

    if not last_parsed_data:
        return jsonify({"error": "Нет данных для загрузки. Сначала загрузите PDF."}), 400

    try:
        # Загружаем текущую базу
        existing_base = load_onis_base()

        # Мержим данные
        result = merge_pumps(existing_base, last_parsed_data)

        # Сохраняем обновленную базу
        if save_onis_base(result['merged']):
            # Очищаем временные данные
            last_parsed_data = None

            return jsonify({
                "success": True,
                "stats": result['stats'],
                "message": f"Добавлено {result['stats']['added']} записей, пропущено {result['stats']['duplicates']} дубликатов"
            })
        else:
            return jsonify({"error": "Ошибка сохранения базы данных"}), 500

    except Exception as e:
        return jsonify({"error": f"Ошибка мержа: {str(e)}"}), 500


@app.route('/stats')
def get_stats():
    """API для получения статистики базы данных"""
    stats = get_database_stats()
    return jsonify(stats)




@app.route('/errors')
def errors():
    """Возвращает последние ошибки"""
    return jsonify({
        'errors': ERROR_LOG,
        'count': len(ERROR_LOG)
    })

@app.route('/preview')
def preview_parsed():
    """Предпросмотр последних распарсенных данных"""
    if not last_parsed_data:
        return jsonify({"error": "Нет данных для предпросмотра"}), 400

    return jsonify({
        "data": last_parsed_data[:100],  # Первые 100 записей
        "total": len(last_parsed_data)
    })




@app.errorhandler(Exception)
def handle_exception(e):
    """Глобальный обработчик ошибок"""
    log_error('UnhandledException', str(e), traceback.format_exc())
    return jsonify({'error': f'Внутренняя ошибка сервера: {str(e)}'}), 500

if __name__ == '__main__':
    # Создаем папку для загрузок если её нет
    os.makedirs(UPLOAD_FOLDER, exist_ok=True)

    # Запускаем сервер
    # host='0.0.0.0' - доступен извне
    # port=5000 - стандартный порт Flask
    app.run(host='0.0.0.0', port=5000, debug=False)
